# Development defaults (used by `vite dev`).
# The e2e harness (playwright webServer) OVERRIDES these with:
#   VITE_ENABLE_MSW=false
#   VITE_API_BASE_URL=http://localhost:8081/api/v1
# so MSW is disabled and requests hit the real ephemeral BE during e2e runs.

# Enable MSW mock service worker for local development (no BE needed).
VITE_ENABLE_MSW=true

# API base URL for the Go backend. Overridden by e2e.
VITE_API_BASE_URL=/api/v1
