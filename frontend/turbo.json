{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "gen": {
      "inputs": ["../docs/api/**/openapi.yaml", "orval.config.ts"],
      "outputs": ["src/gen/**"]
    },
    "build": {
      "dependsOn": ["^build", "gen"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build", "gen"]
    },
    "test": {
      "dependsOn": ["gen"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
