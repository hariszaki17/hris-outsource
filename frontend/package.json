{
  "name": "hris-outsource-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "SWP HRIS Outsource — frontend monorepo (web + mobile + shared packages). See docs/eng/WEB-STACK.md.",
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "gen": "pnpm --filter @swp/api-client gen"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "2.3.3",
    "typescript": "5.7.3"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.0.7"
    }
  }
}
