# HRIS staging env — copy to .env.prod and fill secrets (deploy.sh generates them).
# .env.prod is gitignored. NEVER commit real secrets.

# --- app ---
ENV=production
SERVICE_NAME=hris-api
LOG_LEVEL=info
HTTP_ADDR=:8080

# Public origin (the DuckDNS host behind the additive nginx vhost + TLS).
CORS_ALLOWED_ORIGINS=https://swp-hris.duckdns.org

# --- postgres (compose service `postgres`) ---
POSTGRES_USER=hris
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=hris
# Full DSN the api/worker use (host = compose service name). Password must match above.
DATABASE_URL=postgres://hris:__CHANGE_ME__@postgres:5432/hris?sslmode=disable
DATABASE_MAX_CONNS=10

# --- auth (Ed25519, base64-STD of raw keys: priv 64B, pub 32B) ---
# Generate with the golang one-liner in deploy.sh (matches auth/jwt.go exactly).
AUTH_JWT_PRIVATE_KEY=__CHANGE_ME_base64_64B__
AUTH_JWT_PUBLIC_KEY=__CHANGE_ME_base64_32B__
AUTH_ACCESS_TTL=30m
AUTH_REFRESH_TTL=720h
AUTH_COOKIE_DOMAIN=swp-hris.duckdns.org
AUTH_COOKIE_SECURE=true

# --- payroll field encryption (VERIFY expected length/encoding in config before prod) ---
PAYROLL_ENCRYPTION_KEY=__CHANGE_ME__

# --- object storage (compose service `minio`) ---
STORAGE_ENDPOINT=minio:9000
# Public host the BROWSER hits for presigned URLs (path-style: /<bucket>/<key>).
# Host nginx proxies /hris-private/ -> 127.0.0.1:9100. VERIFY presign after deploy.
STORAGE_PUBLIC_ENDPOINT=swp-hris.duckdns.org
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY=hris-minio
STORAGE_SECRET_KEY=__CHANGE_ME__
STORAGE_BUCKET=hris-private
STORAGE_PRESIGN_TTL=5m
STORAGE_MAX_UPLOAD_BYTES=5242880

# --- background sweeps (defaults are fine) ---
ABSENCE_SWEEP_ENABLED=true
LEAVE_EXPIRY_SWEEP_ENABLED=true

# --- rate limit ---
RATELIMIT_PER_MINUTE=600
RATELIMIT_BURST=60
