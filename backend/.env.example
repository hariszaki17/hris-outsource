# Copy to .env for local dev (godotenv loads it; never commit real secrets).
# Field names map to internal/platform/config/config.go via caarlos0/env tags.

# --- HTTP ---
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s

# --- CORS (web SPA origin). Web and API share parent domain *.swp.example.com,
#     so refresh cookie is SameSite=Lax with Domain=.swp.example.com in prod. ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Database ---
DATABASE_URL=postgres://hris:hris@localhost:5432/hris?sslmode=disable
DATABASE_MAX_CONNS=10

# --- Auth ---
# EdDSA (Ed25519) keys, base64-encoded. Generate dev keys with:
#   go run ./cmd/api genkeys   (TODO helper) — or supply your own.
AUTH_JWT_PRIVATE_KEY=
AUTH_JWT_PUBLIC_KEY=
AUTH_ACCESS_TTL=30m
AUTH_REFRESH_TTL=720h
# Cookie domain for the web refresh cookie (leading dot shares across subdomains).
AUTH_COOKIE_DOMAIN=.swp.example.com
# In dev (http://localhost) set this false so the cookie is sent without HTTPS.
AUTH_COOKIE_SECURE=false

# --- Observability ---
# OTLP trace endpoint; if empty, tracing is a no-op. Metrics are always on at /metrics.
OTEL_EXPORTER_OTLP_ENDPOINT=
SERVICE_NAME=hris-api
ENV=development
LOG_LEVEL=debug

# --- Rate limiting (CONVENTIONS §19) ---
RATELIMIT_PER_MINUTE=600
RATELIMIT_BURST=60

# --- Absence-sweep cron (E5 F5.2; in-process, single binary) ---
# Marks scheduled shifts that ended past the grace with no clock-in as ABSENT.
ABSENCE_SWEEP_ENABLED=true
# Tick period for the sweep.
ABSENCE_SWEEP_INTERVAL=15m
# Mark ABSENT only this long after a shift's end (cutoff = now - grace).
ABSENCE_GRACE=30m

# --- Leave-expiry sweep cron (E6 F6.1; in-process, single binary) ---
# Releases dangling pending_days on lapsed grant-lots (remaining is already 0 for an
# inactive lot at the read boundary; this clears stale reservations).
LEAVE_EXPIRY_SWEEP_ENABLED=true
# Tick period for the leave-expiry sweep.
LEAVE_EXPIRY_INTERVAL=1h

# --- Object storage (MinIO; docker-compose `minio` service) ---
# Single PRIVATE bucket; the API hands out short-TTL presigned URLs (E2 profile
# photos, E5 attendance selfies). API reaches the store at STORAGE_ENDPOINT.
STORAGE_ENDPOINT=localhost:9000
# Host to rewrite into presigned URLs so the browser can reach the store directly.
# Leave empty when STORAGE_ENDPOINT is already browser-reachable (local dev).
STORAGE_PUBLIC_ENDPOINT=
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=hris-private
STORAGE_USE_SSL=false
# Presigned PUT/GET validity (kept short).
STORAGE_PRESIGN_TTL=5m
# Max single upload, bytes (5 MiB) — pinned into the presigned PUT size range.
STORAGE_MAX_UPLOAD_BYTES=5242880
